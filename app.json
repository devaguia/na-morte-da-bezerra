{
  "expo": {
    "name": "Na morte da bezerra",
    "slug": "na-morte-da-bezerra",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "nadmb",
    "platforms": ["ios", "android"],
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nadmb.app"
    },
    "icon": "./assets/bezerra.png",
    "android": {
      "package": "com.nadmb.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/bezerra.png",
        "backgroundColor": "#FBF3EB"
      }
    },
    "plugins": ["expo-router"]
  }
}
